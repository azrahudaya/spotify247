# Telegram Bot
# Create a bot with @BotFather and paste the token below.
TELEGRAM_BOT_TOKEN=1234567890:replace_me
# Comma-separated Telegram user IDs. Get yours with /whoami after the bot is running.
TELEGRAM_ALLOWED_USER_IDS=123456789

# Spotify Web API
# Create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=replace_me
SPOTIFY_CLIENT_SECRET=replace_me
# Generate this with: python3 scripts/spotify_auth.py
SPOTIFY_REFRESH_TOKEN=replace_me
# Add the same URI to your Spotify app settings.
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback
# Optional. Leave empty for controller-only auto device mode.
SPOTIFY_DEVICE_NAME=
SPOTIFY_MARKET=ID

# Bot behavior
BOT_POLL_TIMEOUT_SECONDS=30
BOT_SEARCH_LIMIT=5
LOG_LEVEL=INFO
